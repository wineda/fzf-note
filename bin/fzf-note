#!/usr/bin/env bash
set -euo pipefail

APP_ROOT="$(cd "$(dirname "${BASH_SOURCE[0]}")/.." && pwd)"
WORK_DIR="$APP_ROOT/work"
MERGED_DIR="$WORK_DIR/merged"
NOTE_DIR="$APP_ROOT/note"
NOTE_FILE="$NOTE_DIR/note.md"
PROMPTS_DIR="$APP_ROOT/prompts"
MERGE_PROMPT_FILE="$PROMPTS_DIR/merge.md"

log() {
  printf '[fzf-note] %s\n' "$*" >&2
}

die() {
  log "$*"
  exit 1
}

require_cmds() {
  local cmd
  for cmd in "$@"; do
    command -v "$cmd" >/dev/null 2>&1 || die "required command not found: $cmd"
  done
}

init_repo() {
  mkdir -p "$WORK_DIR" "$MERGED_DIR" "$NOTE_DIR" "$PROMPTS_DIR"
  touch "$NOTE_FILE"

  if [[ ! -f "$MERGE_PROMPT_FILE" ]]; then
    cat > "$MERGE_PROMPT_FILE" <<'PROMPT'
あなたは Markdown ノート統合アシスタントです。

以下の入力を使って、更新後の note/note.md 全文を出力してください。

要件:
- 出力は Markdown 本文のみ（説明文や補足テキストを含めない）
- 既存ノートの情報は削除しない
- 同一・近接トピックは既存の H2 (##) セクションに統合する
- 対応セクションがない場合は新規 H2 セクションを作る
- 重複内容は整理してまとめる
- 曖昧・未確定の内容は「要確認」として残す
- H2 見出し単位で読みやすく整形する
PROMPT
  fi

  if [[ ! -f "$PROMPTS_DIR/codex-gui-merge.md" ]]; then
    cat > "$PROMPTS_DIR/codex-gui-merge.md" <<'PROMPT'
# Codex GUI 向け: work メモ統合依頼

次の手順で作業してください。

1. 現在の作業ツリーを確認する
2. 既存のユーザー変更は戻さない
3. `code/merge-YYYYMMDD-HHMMSS` 形式のブランチを作成する
4. `work/*.md` を読み、`note/note.md` へ H2 単位で統合する
5. 取り込み済み `work/*.md` を `work/merged/` へ移動する
6. 変更を stage する
7. 次のメッセージで commit する

コミットメッセージ:
`chore(note): merge work notes into note.md`
PROMPT
  fi

  log "initialized: work/, work/merged/, note/, note/note.md"
}

today_work_file() {
  date +"$WORK_DIR/%Y-%m-%d.md"
}

cmd_add() {
  mkdir -p "$WORK_DIR"
  local f
  f="$(today_work_file)"
  touch "$f"
  vim "$f"
}

preview_command() {
  local file="$1"
  if command -v bat >/dev/null 2>&1; then
    cat <<'CMD'
line=$(printf '%s\n' "{}" | awk '{print $1}');
[[ "$line" =~ ^[0-9]+$ ]] || line=1
bat --style=numbers --color=always --paging=never --highlight-line "$line" --line-range "$((line>20?line-20:1)):$((line+20))" "FILE_PLACEHOLDER"
CMD
  else
    cat <<'CMD'
line=$(printf '%s\n' "{}" | awk '{print $1}');
[[ "$line" =~ ^[0-9]+$ ]] || line=1
start=$((line>20?line-20:1)); end=$((line+20));
awk -v s="$start" -v e="$end" -v line="$line" 'NR>=s&&NR<=e {prefix=(NR==line?"> ":"  "); printf "%s%5d | %s\n", prefix, NR, $0}' "FILE_PLACEHOLDER"
CMD
  fi
}

open_in_vim_from_selection() {
  local selection="$1"
  [[ -z "$selection" ]] && return 0
  local line
  line="$(awk '{print $1}' <<<"$selection")"
  [[ "$line" =~ ^[0-9]+$ ]] || die "invalid selection: $selection"
  vim "+${line}" "$NOTE_FILE"
}

cmd_search() {
  [[ -f "$NOTE_FILE" ]] || die "missing $NOTE_FILE; run init first"

  local preview
  preview="$(preview_command "$NOTE_FILE")"
  preview="${preview//FILE_PLACEHOLDER/$NOTE_FILE}"
  local -a fzf_opts=(
    --ansi
    --layout=reverse
    --border
    --preview-window=down,60%
  )

  local selection=""
  if [[ -n "${TMUX:-}" ]] && command -v tmux >/dev/null 2>&1; then
    local tmp_out
    tmp_out="$(mktemp)"
    local tmp_script
    tmp_script="$(mktemp)"
    trap 'rm -f "${tmp_out:-}" "${tmp_script:-}"' RETURN

    cat > "$tmp_script" <<'SCRIPT'
#!/usr/bin/env bash
set -euo pipefail

note_file="$1"
preview_cmd="$2"
out_file="$3"
shift 3

nl -ba "$note_file" | awk -F'\t' '$2 ~ /[^[:space:]]/' | fzf "$@" --preview "$preview_cmd" > "$out_file"
SCRIPT
    chmod +x "$tmp_script"

    local popup_cmd
    popup_cmd=$(printf 'bash %q %q %q %q' "$tmp_script" "$NOTE_FILE" "$preview" "$tmp_out")
    local opt
    for opt in "${fzf_opts[@]}"; do
      popup_cmd+=" $(printf '%q' "$opt")"
    done

    tmux display-popup -E "$popup_cmd" || true

    if [[ -s "$tmp_out" ]]; then
      selection="$(cat "$tmp_out")"
    fi
  else
    selection="$({ nl -ba "$NOTE_FILE" | awk -F'\t' '$2 ~ /[^[:space:]]/' | fzf "${fzf_opts[@]}" --preview "$preview"; } || true)"
  fi

  open_in_vim_from_selection "$selection"
}

collect_work_files() {
  mkdir -p "$WORK_DIR"
  find "$WORK_DIR" -maxdepth 1 -type f -name '*.md' | sort
}

build_merge_input() {
  local work_files=("$@")

  [[ -f "$MERGE_PROMPT_FILE" ]] || die "missing prompt: $MERGE_PROMPT_FILE"
  [[ -f "$NOTE_FILE" ]] || touch "$NOTE_FILE"

  {
    printf '# Instructions\n\n'
    cat "$MERGE_PROMPT_FILE"
    printf '\n\n# Existing note/note.md\n\n'
    cat "$NOTE_FILE"
    printf '\n\n# Work notes\n\n'
    local f
    for f in "${work_files[@]}"; do
      printf '## FILE: %s\n\n' "$(basename "$f")"
      cat "$f"
      printf '\n\n'
    done
    printf '# Output format\n\n'
    printf 'Return only the full updated Markdown for note/note.md.\n'
  }
}

create_merge_branch_and_commit() {
  local branch_name="$1"
  git rev-parse --is-inside-work-tree >/dev/null 2>&1 || die "not in a git repository"

  local current_branch
  current_branch="$(git rev-parse --abbrev-ref HEAD)"

  if git show-ref --verify --quiet "refs/heads/$branch_name"; then
    die "branch already exists: $branch_name"
  fi

  git switch -c "$branch_name"

  git add "$NOTE_FILE" "$WORK_DIR"

  if git diff --cached --quiet; then
    log "no changes to commit"
    return 0
  fi

  git commit -m 'chore(note): merge work notes into note.md'
  log "committed on branch: $branch_name (from $current_branch)"
}

cmd_merge_ai() {
  local do_commit=0
  local branch_name=""

  while (($#)); do
    case "$1" in
      --commit)
        do_commit=1
        shift
        ;;
      --branch)
        [[ $# -ge 2 ]] || die "--branch requires a value"
        branch_name="$2"
        shift 2
        ;;
      *)
        die "unknown option for merge-ai: $1"
        ;;
    esac
  done

  [[ -n "${AI_MERGE_CMD:-}" ]] || die "AI_MERGE_CMD is not set"

  mapfile -t work_files < <(collect_work_files)
  if ((${#work_files[@]} == 0)); then
    log "no work/*.md files to merge"
    return 0
  fi

  mkdir -p "$NOTE_DIR" "$MERGED_DIR"

  local tmp_output
  tmp_output="$(mktemp)"
  trap 'rm -f "${tmp_output:-}"' RETURN

  build_merge_input "${work_files[@]}" | bash -lc "$AI_MERGE_CMD" > "$tmp_output"

  if [[ ! -s "$tmp_output" ]]; then
    die "AI output is empty"
  fi

  cp "$tmp_output" "$NOTE_FILE"

  local f
  for f in "${work_files[@]}"; do
    mv "$f" "$MERGED_DIR/"
  done

  log "merged ${#work_files[@]} files into note/note.md and moved to work/merged/"

  if ((do_commit)); then
    [[ -n "$branch_name" ]] || branch_name="codex/merge-notes-$(date +%Y%m%d-%H%M%S)"
    create_merge_branch_and_commit "$branch_name"
  fi
}

usage() {
  cat <<'USAGE'
Usage: ./bin/fzf-note <command> [options]

Commands:
  init                 Initialize required directories and files
  add                  Open today's work/YYYY-MM-DD.md in vim
  search               Search note/note.md by line with fzf and open selection in vim
  merge-ai [options]   Merge work/*.md into note/note.md via AI_MERGE_CMD

merge-ai options:
  --commit             Create branch and commit merged changes
  --branch <name>      Branch name used with --commit
USAGE
}

main() {
  local cmd="${1:-}"
  shift || true

  case "$cmd" in
    init)
      require_cmds bash git
      init_repo
      ;;
    add)
      require_cmds bash vim
      cmd_add "$@"
      ;;
    search)
      require_cmds bash fzf vim
      cmd_search "$@"
      ;;
    merge-ai)
      require_cmds bash git
      cmd_merge_ai "$@"
      ;;
    -h|--help|help)
      usage
      ;;
    *)
      usage
      [[ -n "$cmd" ]] && exit 1
      ;;
  esac
}

main "$@"
