#!/usr/bin/env bash
set -euo pipefail

APP_ROOT="$(cd "$(dirname "${BASH_SOURCE[0]}")/.." && pwd)"
DOC_DIR="${FZF_NOTE_DOC_DIR:-$APP_ROOT/document}"
WORK_DIR="${FZF_NOTE_WORK_DIR:-$DOC_DIR/work}"
MERGED_DIR="${FZF_NOTE_MERGE_DIR:-$DOC_DIR/merge}"
NOTE_DIR="${FZF_NOTE_NOTE_DIR:-$DOC_DIR/note}"
NOTE_FILE="${FZF_NOTE_NOTE_FILE:-$NOTE_DIR/note.md}"
PROMPTS_DIR="$APP_ROOT/prompts"
FORMAT_PROMPT_FILE="$PROMPTS_DIR/format.md"
ORGANIZE_FAST_PROMPT_FILE="$PROMPTS_DIR/organize-fast.md"
NOTE_EDITOR="${FZF_NOTE_EDITOR:-vim}"

log() {
  printf '[fzf-note] %s\n' "$*" >&2
}

die() {
  log "$*"
  exit 1
}

require_cmds() {
  local cmd
  for cmd in "$@"; do
    command -v "$cmd" >/dev/null 2>&1 || die "required command not found: $cmd"
  done
}

init_repo() {
  mkdir -p "$DOC_DIR" "$WORK_DIR" "$MERGED_DIR" "$NOTE_DIR" "$PROMPTS_DIR"
  touch "$NOTE_FILE"

  if [[ ! -f "$FORMAT_PROMPT_FILE" ]]; then
    cat > "$FORMAT_PROMPT_FILE" <<'PROMPT'
あなたは Markdown 整形アシスタントです。

入力された note/note.md 全文を読み、以下の要件で整形済み Markdown 全文を返してください。

要件:
- 出力は Markdown 本文のみ（説明文や補足テキストを含めない）
- 情報は削除しない
- H2 (##) 見出し単位で読みやすく整理する
- 重複や冗長表現は整理する
- 曖昧・未確定の内容は「要確認」として残す
PROMPT
  fi

  if [[ ! -f "$ORGANIZE_FAST_PROMPT_FILE" ]]; then
    cat > "$ORGANIZE_FAST_PROMPT_FILE" <<'PROMPT'
あなたは「大量ノート整理」専任アシスタントです。

入力される note.md 全文を、短時間で再利用しやすい構造に再編してください。

必須ルール:
- 出力は Markdown 本文のみ（前置き・説明禁止）
- 元情報は削除しない（不足情報は「要確認」で明示）
- まず全体を俯瞰し、内容を H2 (##) 見出しで再分類する
- 同種内容は統合し、重複は 1 つに集約する
- 実行可能な内容は「次アクション」に分離する
- 決定事項 / 未決事項 / 参照情報 を明確に分ける
- 長文は要点化し、箇条書き中心で可読性を優先する

推奨構成:
## サマリ
## 決定事項
## 未決事項（要確認）
## 次アクション
## 参照メモ
PROMPT
  fi

  log "initialized: document/work, document/merge, document/note, document/note/note.md"
}

today_work_file() {
  date +"$WORK_DIR/%Y-%m-%d.md"
}

cmd_add() {
  mkdir -p "$WORK_DIR"
  local f
  f="$(today_work_file)"
  touch "$f"
  "$NOTE_EDITOR" "$f"
}

preview_command() {
  local file="$1"
  if command -v bat >/dev/null 2>&1; then
    cat <<'CMD'
line='{1}';
[[ "$line" =~ ^[0-9]+$ ]] || line=1
bat --style=numbers --color=always --paging=never --highlight-line "$line" --line-range "$((line>20?line-20:1)):$((line+20))" "FILE_PLACEHOLDER"
CMD
  else
    cat <<'CMD'
line='{1}';
[[ "$line" =~ ^[0-9]+$ ]] || line=1
start=$((line>20?line-20:1)); end=$((line+20));
awk -v s="$start" -v e="$end" -v line="$line" 'NR>=s&&NR<=e {prefix=(NR==line?"> ":"  "); printf "%s%5d | %s\n", prefix, NR, $0}' "FILE_PLACEHOLDER"
CMD
  fi
}

build_fzf_opts() {
  local help_text
  help_text="$(fzf --help 2>&1 || true)"

  local -a opts=(
    --ansi
    --layout=reverse
    --preview-window=down,60%
  )

  if [[ "$help_text" == *"sharp"* ]]; then
    opts+=(--border=sharp)
  else
    opts+=(--border)
  fi

  if [[ "$help_text" == *"border-"* ]]; then
    opts[2]="--preview-window=down,60%,border-top"
  fi

  printf '%s\n' "${opts[@]}"
}

open_in_vim_from_selection() {
  local selection="$1"
  [[ -z "$selection" ]] && return 0
  local line
  line="$(awk '{print $1}' <<<"$selection")"
  [[ "$line" =~ ^[0-9]+$ ]] || die "invalid selection: $selection"
  "$NOTE_EDITOR" "+${line}" "$NOTE_FILE"
}

cmd_search() {
  [[ -f "$NOTE_FILE" ]] || die "missing $NOTE_FILE; run init first"

  local preview
  preview="$(preview_command "$NOTE_FILE")"
  preview="${preview//FILE_PLACEHOLDER/$NOTE_FILE}"
  local -a fzf_opts=()
  mapfile -t fzf_opts < <(build_fzf_opts)

  local selection=""
  if [[ -n "${TMUX:-}" ]] && command -v fzf-tmux >/dev/null 2>&1; then
    selection="$({ nl -ba "$NOTE_FILE" | awk -F'\t' '$2 ~ /[^[:space:]]/' | fzf-tmux -p 90%,85% "${fzf_opts[@]}" --preview "$preview"; } || true)"
  else
    selection="$({ nl -ba "$NOTE_FILE" | awk -F'\t' '$2 ~ /[^[:space:]]/' | fzf "${fzf_opts[@]}" --preview "$preview"; } || true)"
  fi

  open_in_vim_from_selection "$selection"
}

collect_work_files() {
  mkdir -p "$WORK_DIR"
  find "$WORK_DIR" -maxdepth 1 -type f -name '*.md' | sort
}

cmd_merge() {
  mapfile -t work_files < <(collect_work_files)
  if ((${#work_files[@]} == 0)); then
    log "no work/*.md files to merge"
    return 0
  fi

  mkdir -p "$NOTE_DIR"
  mkdir -p "$MERGED_DIR"
  touch "$NOTE_FILE"

  local f
  for f in "${work_files[@]}"; do
    {
      printf '\n\n'
      cat "$f"
    } >> "$NOTE_FILE"
    mv "$f" "$MERGED_DIR/"
  done

  log "appended ${#work_files[@]} files into document/note/note.md and moved to document/merge/"

  if git -C "$DOC_DIR" rev-parse --is-inside-work-tree >/dev/null 2>&1; then
    local -a merged_names=()
    local name
    for f in "${work_files[@]}"; do
      name="$(basename "$f")"
      merged_names+=("$name")
    done

    local commit_msg
    if ((${#merged_names[@]} == 1)); then
      commit_msg="note.mdに${merged_names[0]}をマージ"
    else
      commit_msg="note.mdに${merged_names[0]}ほか$((${#merged_names[@]} - 1))件をマージ"
    fi

    git -C "$DOC_DIR" add -A
    if git -C "$DOC_DIR" diff --cached --quiet; then
      log "no changes to commit in $DOC_DIR"
      return 0
    fi
    git -C "$DOC_DIR" commit -m "$commit_msg"
    log "committed in $DOC_DIR: $commit_msg"
  else
    log "skip commit: $DOC_DIR is not a git repository"
  fi
}

cmd_backup() {
  [[ -n "${FZF_NOTE_BACKUP_DIR:-}" ]] || die "FZF_NOTE_BACKUP_DIR is not set"
  mkdir -p "$FZF_NOTE_BACKUP_DIR"

  local ts archive_path
  ts="$(date +'%Y%m%d-%H%M%S')"
  archive_path="$FZF_NOTE_BACKUP_DIR/$ts.tar.gz"

  tar -czf "$archive_path" -C "$(pwd)" .
  log "created backup: $archive_path"
}

cmd_format_ai() {
  [[ -n "${AI_FORMAT_CMD:-}" ]] || die "AI_FORMAT_CMD is not set"
  [[ -f "$NOTE_FILE" ]] || die "missing $NOTE_FILE; run init first"
  [[ -f "$FORMAT_PROMPT_FILE" ]] || die "missing prompt: $FORMAT_PROMPT_FILE"

  local tmp_output
  tmp_output="$(mktemp)"
  trap 'rm -f "${tmp_output:-}"' RETURN

  {
    printf '# Instructions\n\n'
    cat "$FORMAT_PROMPT_FILE"
    printf '\n\n# note/note.md\n\n'
    cat "$NOTE_FILE"
    printf '\n'
  } | bash -lc "$AI_FORMAT_CMD" > "$tmp_output"

  if [[ ! -s "$tmp_output" ]]; then
    die "AI output is empty"
  fi

  cp "$tmp_output" "$NOTE_FILE"
  log "formatted note/note.md via AI"
}

usage() {
  cat <<'USAGE'
Usage: ./bin/fzf-note <command>

Commands:
  init        Initialize required directories and files under document/
  add         Open today's document/work/YYYY-MM-DD.md in $FZF_NOTE_EDITOR (default: vim)
  search      Search document/note/note.md by line with fzf and open selection in $FZF_NOTE_EDITOR
  merge       Append all document/work/*.md to the end of document/note/note.md
  backup      Archive current directory to $FZF_NOTE_BACKUP_DIR/yyyymmdd-hhmmss.tar.gz
  format-ai   Format document/note/note.md by AI_FORMAT_CMD (manual)
USAGE
}

main() {
  local cmd="${1:-}"
  shift || true

  case "$cmd" in
    init)
      require_cmds bash git
      init_repo
      ;;
    add)
      require_cmds bash "$NOTE_EDITOR"
      cmd_add "$@"
      ;;
    search)
      require_cmds bash fzf "$NOTE_EDITOR"
      cmd_search "$@"
      ;;
    merge)
      require_cmds bash
      cmd_merge "$@"
      ;;
    backup)
      require_cmds bash tar
      cmd_backup "$@"
      ;;
    format-ai)
      require_cmds bash
      cmd_format_ai "$@"
      ;;
    -h|--help|help)
      usage
      ;;
    *)
      usage
      [[ -n "$cmd" ]] && exit 1
      ;;
  esac
}

main "$@"
