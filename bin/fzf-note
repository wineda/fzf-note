#!/usr/bin/env bash
set -euo pipefail

APP_ROOT="$(cd "$(dirname "${BASH_SOURCE[0]}")/.." && pwd)"
WORK_DIR="$APP_ROOT/work"
MERGED_DIR="$WORK_DIR/merged"
NOTE_DIR="$APP_ROOT/note"
NOTE_FILE="$NOTE_DIR/note.md"
PROMPTS_DIR="$APP_ROOT/prompts"
FORMAT_PROMPT_FILE="$PROMPTS_DIR/format.md"

log() {
  printf '[fzf-note] %s\n' "$*" >&2
}

die() {
  log "$*"
  exit 1
}

require_cmds() {
  local cmd
  for cmd in "$@"; do
    command -v "$cmd" >/dev/null 2>&1 || die "required command not found: $cmd"
  done
}

init_repo() {
  mkdir -p "$WORK_DIR" "$MERGED_DIR" "$NOTE_DIR" "$PROMPTS_DIR"
  touch "$NOTE_FILE"

  if [[ ! -f "$FORMAT_PROMPT_FILE" ]]; then
    cat > "$FORMAT_PROMPT_FILE" <<'PROMPT'
あなたは Markdown 整形アシスタントです。

入力された note/note.md 全文を読み、以下の要件で整形済み Markdown 全文を返してください。

要件:
- 出力は Markdown 本文のみ（説明文や補足テキストを含めない）
- 情報は削除しない
- H2 (##) 見出し単位で読みやすく整理する
- 重複や冗長表現は整理する
- 曖昧・未確定の内容は「要確認」として残す
PROMPT
  fi

  log "initialized: work/, work/merged/, note/, note/note.md"
}

today_work_file() {
  date +"$WORK_DIR/%Y-%m-%d.md"
}

cmd_add() {
  mkdir -p "$WORK_DIR"
  local f
  f="$(today_work_file)"
  touch "$f"
  vim "$f"
}

preview_command() {
  local file="$1"
  if command -v bat >/dev/null 2>&1; then
    cat <<'CMD'
line='{1}';
[[ "$line" =~ ^[0-9]+$ ]] || line=1
bat --style=numbers --color=always --paging=never --highlight-line "$line" --line-range "$((line>20?line-20:1)):$((line+20))" "FILE_PLACEHOLDER"
CMD
  else
    cat <<'CMD'
line='{1}';
[[ "$line" =~ ^[0-9]+$ ]] || line=1
start=$((line>20?line-20:1)); end=$((line+20));
awk -v s="$start" -v e="$end" -v line="$line" 'NR>=s&&NR<=e {prefix=(NR==line?"> ":"  "); printf "%s%5d | %s\n", prefix, NR, $0}' "FILE_PLACEHOLDER"
CMD
  fi
}

build_fzf_opts() {
  local help_text
  help_text="$(fzf --help 2>&1 || true)"

  local -a opts=(
    --ansi
    --layout=reverse
    --preview-window=down,60%
  )

  if [[ "$help_text" == *"sharp"* ]]; then
    opts+=(--border=sharp)
  else
    opts+=(--border)
  fi

  if [[ "$help_text" == *"border-"* ]]; then
    opts[2]="--preview-window=down,60%,border-top"
  fi

  printf '%s\n' "${opts[@]}"
}

open_in_vim_from_selection() {
  local selection="$1"
  [[ -z "$selection" ]] && return 0
  local line
  line="$(awk '{print $1}' <<<"$selection")"
  [[ "$line" =~ ^[0-9]+$ ]] || die "invalid selection: $selection"
  vim "+${line}" "$NOTE_FILE"
}

cmd_search() {
  [[ -f "$NOTE_FILE" ]] || die "missing $NOTE_FILE; run init first"

  local preview
  preview="$(preview_command "$NOTE_FILE")"
  preview="${preview//FILE_PLACEHOLDER/$NOTE_FILE}"
  local -a fzf_opts=()
  mapfile -t fzf_opts < <(build_fzf_opts)

  local selection=""
  if [[ -n "${TMUX:-}" ]] && command -v fzf-tmux >/dev/null 2>&1; then
    selection="$({ nl -ba "$NOTE_FILE" | awk -F'\t' '$2 ~ /[^[:space:]]/' | fzf-tmux -p 90%,85% "${fzf_opts[@]}" --preview "$preview"; } || true)"
  else
    selection="$({ nl -ba "$NOTE_FILE" | awk -F'\t' '$2 ~ /[^[:space:]]/' | fzf "${fzf_opts[@]}" --preview "$preview"; } || true)"
  fi

  open_in_vim_from_selection "$selection"
}

collect_work_files() {
  mkdir -p "$WORK_DIR"
  find "$WORK_DIR" -maxdepth 1 -type f -name '*.md' | sort
}

cmd_merge() {
  mapfile -t work_files < <(collect_work_files)
  if ((${#work_files[@]} == 0)); then
    log "no work/*.md files to merge"
    return 0
  fi

  mkdir -p "$NOTE_DIR"
  touch "$NOTE_FILE"

  local f
  for f in "${work_files[@]}"; do
    {
      printf '\n\n'
      cat "$f"
    } >> "$NOTE_FILE"
  done

  log "appended ${#work_files[@]} files into note/note.md"
}

cmd_format_ai() {
  [[ -n "${AI_FORMAT_CMD:-}" ]] || die "AI_FORMAT_CMD is not set"
  [[ -f "$NOTE_FILE" ]] || die "missing $NOTE_FILE; run init first"
  [[ -f "$FORMAT_PROMPT_FILE" ]] || die "missing prompt: $FORMAT_PROMPT_FILE"

  local tmp_output
  tmp_output="$(mktemp)"
  trap 'rm -f "${tmp_output:-}"' RETURN

  {
    printf '# Instructions\n\n'
    cat "$FORMAT_PROMPT_FILE"
    printf '\n\n# note/note.md\n\n'
    cat "$NOTE_FILE"
    printf '\n'
  } | bash -lc "$AI_FORMAT_CMD" > "$tmp_output"

  if [[ ! -s "$tmp_output" ]]; then
    die "AI output is empty"
  fi

  cp "$tmp_output" "$NOTE_FILE"
  log "formatted note/note.md via AI"
}

usage() {
  cat <<'USAGE'
Usage: ./bin/fzf-note <command>

Commands:
  init        Initialize required directories and files
  add         Open today's work/YYYY-MM-DD.md in vim
  search      Search note/note.md by line with fzf and open selection in vim
  merge       Append all work/*.md to the end of note/note.md
  format-ai   Format note/note.md by AI_FORMAT_CMD (manual)
USAGE
}

main() {
  local cmd="${1:-}"
  shift || true

  case "$cmd" in
    init)
      require_cmds bash git
      init_repo
      ;;
    add)
      require_cmds bash vim
      cmd_add "$@"
      ;;
    search)
      require_cmds bash fzf vim
      cmd_search "$@"
      ;;
    merge)
      require_cmds bash
      cmd_merge "$@"
      ;;
    format-ai)
      require_cmds bash
      cmd_format_ai "$@"
      ;;
    -h|--help|help)
      usage
      ;;
    *)
      usage
      [[ -n "$cmd" ]] && exit 1
      ;;
  esac
}

main "$@"
